{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 3008,
      "excludeFiles": "{python-api/.venv/**,python-api/**/__pycache__/**,.venv/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ]
}
